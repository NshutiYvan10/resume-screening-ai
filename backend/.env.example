# ---- Database ----
DB_URL=jdbc:postgresql://localhost:5432/resume_screening
DB_USERNAME=postgres
DB_PASSWORD=change-me

# ---- Security ----
# Use a random string of at least 32 characters in production
JWT_SECRET=please-change-this-to-a-long-random-secret-value
JWT_ACCESS_MINUTES=30
JWT_REFRESH_DAYS=7

# ---- Seeded platform super admin (created on first boot) ----
SEED_ADMIN_EMAIL=admin@resumeai.local
SEED_ADMIN_PASSWORD=Admin@12345
SEED_ADMIN_NAME=Platform Administrator

# ---- AI microservice ----
AI_SERVICE_URL=http://localhost:8001
AI_SERVICE_API_KEY=change-me-internal-key

# ---- Frontend / CORS ----
FRONTEND_BASE_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# ---- File storage ----
STORAGE_ROOT=./storage

# ---- SMTP (email) ----
# MAIL_ENABLED=false disables outbound email; action links are still logged to the console.
MAIL_ENABLED=true
MAIL_FROM=no-reply@resumeai.local
MAIL_FROM_NAME=ResumeAI Screening
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_AUTH=false
SMTP_STARTTLS=false
